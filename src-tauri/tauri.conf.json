{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tu asistente Local",
  "version": "0.1.0",
  "identifier": "com.tuasistentelocal.app",
  "build": {
    "frontendDist": "../dist/spa",
    "devUrl": "http://localhost:9005",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Tu asistente Local",
        "width": 1150,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "nsis",
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "pendiente_de_generar",
      "endpoints": [
        "https://github.com/vissanum/TaL/releases/latest/download/latest.json"
      ]
    }
  }
}
