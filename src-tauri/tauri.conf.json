{
  "productName": "Tu asistente Local",
  "version": "0.1.0",
  "identifier": "com.tuasistentelocal.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9005",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tu asistente Local",
        "width": 1150,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "pendiente_de_generar //TODO: Pendiente generar pubkey para updater.",
      "endpoints": [
        "https://github.com/vissanum/TaL/releases/latest/download/latest.json"
      ],
      "dialog": "TODO: Considerar si queremos un diálogo por defecto para las actualizaciones Tarea 1.1.6",
      "mi-plugin": {
        "configValue": "TODO: Valorar más adelante si se añaden plugins "
      }
    }
  }
}
