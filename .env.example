# TaL - Variables de Entorno de Ejemplo
# Copia este archivo a .env en la raíz del proyecto y rellena los valores necesarios.
# Las variables comentadas son opcionales o tienen valores por defecto razonables.

# -- Nivel de Log para el Backend Rust --
# Valores posibles: TRACE, DEBUG, INFO, WARN, ERROR
# RUST_LOG=INFO

# -- Configuración del Motor de Inferencia Local (Candle) --
# Ruta al directorio donde se buscarán/guardarán los modelos locales por defecto
# LOCAL_MODEL_DEFAULT_PATH=
# Dispositivo de inferencia preferido (si se implementa selección)
# LOCAL_INFERENCE_DEVICE=cpu # Opciones futuras: cuda, metal

# -- Configuración de la Base de Datos Vectorial (LanceDB) --
# Ruta base donde se crearán/almacenarán las bases de datos vectoriales de LanceDB
# Si está vacío, se usará una ruta por defecto dentro del directorio de datos de la aplicación.
# LANCEDB_BASE_PATH=

# -- Proveedores de IA Remotos --
# Descomenta y rellena las claves API para los servicios que quieras usar.

# OpenAI
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1" # Opcional, para proxies
# OPENAI_ORG_ID="" # Opcional

# Anthropic
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_BASE_URL="https://api.anthropic.com" # Opcional
# ANTHROPIC_API_VERSION="2023-06-01" # Opcional

# Google Gemini
# GOOGLE_GEMINI_API_KEY="..."
# GOOGLE_GEMINI_BASE_URL="https://generativelanguage.googleapis.com" # Opcional

# Otros proveedores (ejemplos, añadir según se implementen)
# OTHER_PROVIDER_API_KEY="..."
# OTHER_PROVIDER_BASE_URL="..."

# -- URLs de Servicios TaL --
# URL del sitio web público de TaL (para enlaces de ayuda, etc.)
# TAL_PUBLIC_WEBSITE_URL="https://tu-agente-local.github.io/docs/" # O la URL final que se decida
# Endpoint del actualizador de Tauri (normalmente configurado en tauri.conf.json,
# pero puede ser sobreescrito aquí para desarrollo o proxies)
# TAL_UPDATER_ENDPOINT=""

# -- Configuración de Plugins o Funcionalidades Específicas --
# Ejemplo: Si tuviéramos un plugin de búsqueda web que usa SearXNG
# SEARXNG_INSTANCE_URL="http://localhost:8080" # Si el usuario tiene una instancia local

# -- Futuro: Configuración Cliente-Servidor --
# TAL_SERVER_API_URL=""
# TAL_SERVER_API_KEY=""
