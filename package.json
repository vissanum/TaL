    "vue-tsc": "^2.2.10"
  },
  "engines": {
    "node": "^24 || ^22 || >=20.11.0",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
