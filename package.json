    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "md-editor-v3": "^5.6.0",
    "pdfjs-dist": "^5.2.133",
    "pinia": "^2.3.1",
    "quasar": "^2.18.1",
    "vue": "^3.5.14",
    "vue-draggable-plus": "^0.6.0",
    "vue-i18n": "^11.1.4",
