{
  "name": "tal",
  "version": "0.1.0",
  "description": "TaL (Tu asistente Local): Aplicación de escritorio (Tauri v2, Rust, Quasar/Vue3) con IA local/remota, RAG y foco en privacidad.",
  "productName": "Tu asistente Local",
  "author": "Vissanum <vissanumweb@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "dev:tauri": "pnpm tauri dev",
    "build:tauri": "pnpm tauri build",
    "lint:frontend": "eslint --ext .js,.ts,.vue ./",
    "format:frontend": "prettier --write \"**/*.{js,ts,vue,json,md,html,css,scss}\"",
    "format:frontend:check": "prettier --check \"**/*.{js,ts,vue,json,md,html,css,scss}\"",
    "check:frontend:types": "vue-tsc --noEmit",
    "check:rust": "cd src-tauri && cargo check && cd ..",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets -- -D warnings && cd ..",
    "format:rust": "cd src-tauri && cargo fmt && cd ..",
    "format:rust:check": "cd src-tauri && cargo fmt --check && cd ..",
    "lint": "pnpm lint:frontend && pnpm lint:rust",
    "format": "pnpm format:frontend && pnpm format:rust",
    "format:check": "pnpm format:frontend:check && pnpm format:rust:check",
    "check:all": "pnpm check:frontend:types && pnpm check:rust",
    "test": "echo \"No test specified\" && exit 0",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "sync-version": "node scripts/sync-version.js"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@ai-sdk/openai-compatible": "^0.2.14",
    "@bradenmacdonald/s3-lite-client": "npm:@jsr/bradenmacdonald__s3-lite-client@^0.8.0",
    "@cfworker/json-schema": "4.1.1",
